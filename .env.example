# Telegram Bot Token (от @BotFather)
BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Ваш Telegram ID (узнать у @userinfobot)
ADMIN_ID=123456789

# ID канала (например: -1002273965696)
CHANNEL_ID=-1002273965696

# API ключ Groq (https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Настройки (можно оставить по умолчанию)
WEBSITE_URL=https://farang-fm.netlify.app/
CHANNEL_URL=https://t.me/farangfm
BOT_USERNAME=farangfm_bot

# PostgreSQL (Render подставит сам, не нужно заполнять)
DATABASE_URL=postgresql://...
